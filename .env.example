# Mission Control Environment Configuration
# Copy this file to .env and fill in your credentials

# Telegram Configuration
# 1. Create bot via @BotFather on Telegram
# 2. Get your Chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Configuration
# 1. Create webhook in Discord server settings (Server → Webhooks)
# 2. Copy the webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Auto-Restart Configuration
# Set to 'true' to enable automatic service restarts when services are down
AUTO_RESTART=false

# Backend Server Port
PORT=3001

# Frontend Port (handled by Vite, but useful for reference)
FRONTEND_PORT=5173
